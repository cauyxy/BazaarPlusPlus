{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "steam://*"
        }
      ]
    },
    "dialog:default"
  ]
}
