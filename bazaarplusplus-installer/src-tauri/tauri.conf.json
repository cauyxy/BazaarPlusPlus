{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BazaarPlusPlus",
  "version": "4.2.0",
  "identifier": "com.bazaarplusplus.bppinstaller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:14207",
    "beforeBuildCommand": "npm run prebuild-check && npm run build",
    "beforeBundleCommand": "node scripts/before-bundle-cleanup.mjs",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "BazaarPlusPlus",
        "width": 1000,
        "height": 720,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://bppinstaller.bazaarplusplus.com/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1RTAyMzg1RUFEQUNFRUYKUldUdnp0cnFoU1BnOVEzYjFlMFZMcEpmQ014VUZkNWtoRGtybW9pU0UwVjhIUmJmRjdoSmFSTVoK"
    }
  }
}
